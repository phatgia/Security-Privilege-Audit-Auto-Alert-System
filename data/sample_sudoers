# Specific commands only
helpdesk     ALL=(ALL) NOPASSWD: /usr/bin/passwd [A-Za-z]*, /usr/bin/id
monitoring   ALL=(ALL) NOPASSWD: /usr/bin/ss, /usr/bin/netstat, /usr/bin/top
