# Root privileges - standard
root    ALL=(ALL:ALL) ALL

# Members of the admin group may gain root privileges
%admin ALL=(ALL) ALL

# Allow members of group sudo to execute any command
%sudo   ALL=(ALL:ALL) ALL

# Allow members of group wheel to execute any command (RHEL/CentOS)
%wheel  ALL=(ALL:ALL) ALL

# --- Individual user overrides ---

# System administrators
john.doe     ALL=(ALL) NOPASSWD: ALL
jane.smith   ALL=(ALL) NOPASSWD: ALL
michael.lee  ALL=(ALL) NOPASSWD: /usr/bin/apt, /usr/bin/systemctl

# DevOps team
devops01     ALL=(ALL) NOPASSWD: /usr/bin/docker, /usr/bin/kubectl
deploy_svc   ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart *, /usr/bin/journalctl

# Backup service account  
backup_agent ALL=(ALL) NOPASSWD: /usr/bin/rsync, /usr/bin/tar

# Legacy/old accounts (should be reviewed)
